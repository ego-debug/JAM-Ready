# JAM-Ready environment template.
#
# HOW TO USE:
#   1. Copy this file to .env.local   (cp .env.example .env.local)
#   2. Fill in your real values in .env.local
#   3. .env.local is gitignored, so your real secrets are never committed.
#
# This template (.env.example) holds placeholders only. Never put real
# secrets in here. The app runs locally with sensible defaults even if these
# are unset; set them before deploying or sharing.

# ---------------------------------------------------------------------------
# Admin / crew login  (set real values before deploying)
# ---------------------------------------------------------------------------
# Password the dispatcher and crew use at /login
ADMIN_PASSWORD=
# Long random string that signs the session cookie (e.g. 32+ chars)
ADMIN_SESSION_SECRET=

# ---------------------------------------------------------------------------
# Site URL  (canonical links, sitemap, OpenGraph)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=

# ---------------------------------------------------------------------------
# Analytics + Search Console  (optional; nothing loads until set)
# ---------------------------------------------------------------------------
# Plausible (privacy-friendly): your site domain, e.g. jamreadynj.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Or Google Analytics 4 measurement id, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Google Search Console verification token
GOOGLE_SITE_VERIFICATION=

# ---------------------------------------------------------------------------
# Email (Resend)  (optional; without it, status emails are logged not sent)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
# From address, e.g. JAM-Ready <hello@yourdomain.com>
EMAIL_FROM=
# Base URL used inside email links (usually same as NEXT_PUBLIC_SITE_URL)
APP_URL=

# ---------------------------------------------------------------------------
# Supabase (later: Postgres + Auth + Storage to replace the local store)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
