# Copy to .env.local and fill in. The app runs locally without any of these
# (sensible dev defaults are baked in), but set them before sharing/deploying.

# --- Admin auth (Segment 3) ---
# Password the dispatcher/crew use to sign in at /login
ADMIN_PASSWORD=turnready
# Random secret that signs the session cookie — change this to anything long
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# --- Site URL (canonical URLs, sitemap, OG tags) ---
# NEXT_PUBLIC_SITE_URL=https://www.jamreadynj.com

# --- Analytics (optional; nothing loads until set) ---
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=jamreadynj.com
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# GOOGLE_SITE_VERIFICATION=your-search-console-token

# --- Later: Supabase (Postgres + Auth + Storage) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (customer status emails, Segment 7) ---
# Without these, emails are logged + recorded but not sent (local dev works fine).
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=TurnReady <hello@yourdomain.com>
# APP_URL=http://localhost:3100   # base for links inside emails (your real domain in prod)
